# Backend Environment Variables

# Server Configuration
PORT=4000
NODE_ENV=development

# Production Configuration (uncomment for production)
# NODE_ENV=production
# PORT=3000 (for Railway/Render)

# CORS Configuration
# FRONTEND_URL=http://localhost:3000
# For production:
# FRONTEND_URL=https://your-frontend-url.vercel.app

# Database Configuration
# DATABASE_PATH=./database/radar.db (default, local file)
# For production, consider cloud database:
# DATABASE_URL=postgresql://user:password@host:5432/radar

# Scheduler Configuration
# ENABLE_SCHEDULER=true
# SCHEDULER_INTERVAL=21600000 (6 hours in milliseconds)

# Scraper Configuration
# SCRAPER_TIMEOUT=3600000 (1 hour in milliseconds)
# SCRAPER_HEADLESS=true
